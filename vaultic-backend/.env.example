# Vaultic backend environment вЂ” see design В§10.5.
# Copy to `.env` (dev) or `.env.production` (deploy) and fill in real values.
# NEVER commit a populated `.env` вЂ” only `.env.example`.

# в”Ђв”Ђв”Ђ Database в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Neon serverless Postgres; TLS required in production.
#
# Two URLs are required:
#   DATABASE_URL вЂ” pooled endpoint (hostname contains "-pooler"), used for
#     runtime queries. Append `pgbouncer=true` so Prisma treats it as a
#     transaction-pooled connection.
#   DIRECT_URL   вЂ” unpooled endpoint (no "-pooler" in hostname), used by
#     `prisma migrate` for schema changes. Prisma reads this via the
#     `directUrl` field in schema.prisma.
#
# Fetch both via `neonctl connection-string --project-id <id> --pooled`
# and `neonctl connection-string --project-id <id>` respectively.
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/vaultic?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@host.region.aws.neon.tech/vaultic?sslmode=require

# в”Ђв”Ђв”Ђ Solana в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Devnet RPC (public endpoint or Helius).
SOLANA_RPC_URL=https://api.devnet.solana.com

# Vaultic program id вЂ” written by scripts/sync-ids.sh after `anchor deploy`.
VAULTIC_PROGRAM_ID=5igWLTbdAjGfAZKsK9G3Buhe7mkrgC3GEYkQaD4PrTnZ

# Pinned external program ids (design В§1.2).
ENCRYPT_PROGRAM_ID=4ebfzWdKnrnGseuQpezXdG8yCdHqwQ1SSBHD3bWArND8
IKA_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY

# в”Ђв”Ђв”Ђ External services (off-chain) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Ika network gRPC endpoint (DKG, sign-request polling).
IKA_GRPC_URL=grpc://devnet.ika.xyz:50051

# Encrypt network gRPC endpoint (read-only health check).
ENCRYPT_GRPC_URL=grpc://devnet.encrypt.xyz:50051

# в”Ђв”Ђв”Ђ HTTP server в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Port Railway/Render assigns at runtime; 3000 is a sensible local default.
PORT=3000

# CORS allowlist вЂ” only requests from this exact origin are accepted (Req 29.2).
FRONTEND_ORIGIN=http://localhost:3001

# pino log level: trace | debug | info | warn | error | fatal.
LOG_LEVEL=info
